  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 8dbb56d715afdf24fa125d6c889d3d34, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTrigger
  mode: 1
  startKey: 102
  promptObject: {fileID: 0}
  lines:
  - "L\xE1nzalos: son tu arma contra lo que se cruce en tu camino."
  - 'Recuerda esto: <i>algunas cosas resisten un golpe... pero no muchos.</i> Con
    suficientes impactos, hasta lo firme se quiebra.'
  - "Mas si una moneda queda <i>clavada</i> en la piedra, el tir\xF3n no basta: <b>emp\xFAjala</b>
    primero para soltarla, y solo entonces atr\xE1ela."
  - 'Recuerda esto: <i>algunas cosas resisten un golpe... pero no muchos.</i> Con
    suficientes impactos, hasta lo firme se quiebra.'
  once: 1
  delay: 0
  playerTag: Player
