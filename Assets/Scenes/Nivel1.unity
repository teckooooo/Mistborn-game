  m_Script: {fileID: 11500000, guid: 8dbb56d715afdf24fa125d6c889d3d34, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTrigger
  mode: 1
  startKey: 102
  promptObject: {fileID: 1875385220}
  lines:
  - "Despierta. El mundo que conociste ardi\xF3 hasta la ceniza."
  - "Soy <color=#9ad8ff>Armon\xEDa</color>. Mi voz te guiar\xE1 donde otros callan."
  - "Llevas metal en la sangre: <i>Hierro</i> y <i>Acero</i>. Apr\xE9ndelos."
  - Con el Acero empujas <i>E</i> ; con el Hierro atraes <i>Click derecho</i> . El
    metal es tu ancla y tu arma.
  - "Lev\xE1ntate, Nacido de la Bruma. A\xFAn queda esperanza... incluso aqu\xED."
  once: 1
  delay: 0
  playerTag: Player
