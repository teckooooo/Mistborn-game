  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "MOVIMIENTO\r\n  WASD / Flechas     Moverse\r\n  Espacio            Saltar\r\n 
    Shift + direcci\xF3n  Dash\r\n\r\nALOMANCIA\r\n  Q                  Steel Push
    \u2014 empujar metales\r\n  Click derecho      Iron Pull  \u2014 atraer metales\r\n 
    LeftCtrl           Pewter     \u2014 velocidad y salto\r\n  F                 
    Duraluminio \u2014 amplifica metal activo\r\n\r\nPROYECTILES\r\n  E                 
    Lanzar moneda\r\n  R                  Lanzar clavo\r\n\r\nFRASCOS\r\n  1 / 2
    / 3 / 4     Usar frasco de Acero / Hierro / Esta\xF1o / Duraluminio\r\n\r\nCOMBATE\r\n 
    Click izquierdo    Atacar"
  m_isRightToLeft: 0
